<IfModule mod_rewrite.c>
    RewriteEngine On

    # ---------------------------------------
    # 1️⃣ Forzar HTTPS + quitar www
    # ---------------------------------------
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} ^www\.lacubanapizzeria\.com$ [NC]
    RewriteRule ^(.*)$ https://lacubanapizzeria.com/$1 [L,R=301]

    # ---------------------------------------
    # 2️⃣ Redirigir todo a /public
    # ---------------------------------------
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>